baudrate=115200
ipaddr=192.168.1.1
serverip=192.168.1.254
ethaddr=aa:bb:cc:dd:ee:ff
loadaddr=0x88000000
mtdids=nand0=nand.0
mtdparts=mtdparts=nand.0:512k(u-boot),512k(u-boot-env),512k(exp),512k(factory),-(ubi)
bootcmd=run ubi_read_firmware && bootm $loadaddr
bootfile_initramfs=initramfs.bin
bootfile_firmware=firmware.bin
bootfile_uboot=u-boot.bin
bootmenu_0=[32m[1mRun default boot command[0m=run boot_default
bootmenu_1=[32m[1mBoot system from Flash[0m=run bootcmd ; run bootmenu_confirm_return
bootmenu_2=[33m[1mBoot system from TFTP[0m=run boot_tftp_load_initramfs ; run bootmenu_confirm_return
bootmenu_3=[33m[1mLoad system via TFTP then write to flash[0m=run boot_tftp_write_system ; run bootmenu_confirm_return
bootmenu_4=[31m[1mLoad U-Boot via TFTP then write to flash[0m=run boot_tftp_write_uboot ; run bootmenu_confirm_return
bootmenu_5=[31m[1mLoad U-Boot via TTL then write to flash[0m=run boot_uart_write_uboot ; run bootmenu_confirm_return
bootmenu_6=[34m[1mReboot[0m=reset
bootmenu_confirm_return=askenv - [36m[1mPress ENTER to return to menu![0m ; bootmenu 60
boot_default=if test -n $bootmode && test bootmode != normal ; then run boot_entry1 ; else run bootcmd ; fi
boot_entry1=if test $bootmode = mode1 ; then run boot_tftp_write_system_forever ; else run boot_entry2 ; fi
boot_entry2=if test $bootmode = mode2 ; then run boot_tftp_write_system_forever ; else run boot_entry3 ; fi
boot_entry3=if test $bootmode = mode3 ; then run boot_tftp_load_initramfs_forever ; else run boot_entry4 ; fi
boot_entry4=if test $bootmode = mode4 ; then run boot_tftp_load_initramfs_forever ; else run bootcmd ; fi
boot_tftp_load_initramfs=tftpboot $loadaddr $bootfile_initramfs && bootm $loadaddr
boot_tftp_load_initramfs_forever=while true ; do run boot_tftp_load_initramfs ; sleep 3 ; done
boot_tftp_write_system=tftpboot $loadaddr $bootfile_firmware && iminfo $loadaddr && run ubi_write_firmware && bootm $loadaddr
boot_tftp_write_system_forever=while true ; do run boot_tftp_write_system ; sleep 3 ; done
boot_tftp_write_uboot=tftpboot $loadaddr $bootfile_uboot && run nand_write_uboot
boot_uart_write_uboot=loadx $loadaddr $baudrate && run nand_write_uboot
nand_verify_uboot=mtd read u-boot $loadaddr && md5sum $loadaddr 0x$filesize
nand_write_cal_wrsize=setexpr wrsize 0x$filesize + 0x7ff && setexpr wrsize 0x$wrsize / 0x800 && setexpr wrsize 0x$wrsize * 0x800
nand_write_confirm=askenv confirm [35m[1mPress Y then ENTER to confirm write to flash![0m 0x1 && flag=$confirm && setenv confirm && test -n $flag && test $flag = Y
nand_write_uboot=md5sum $loadaddr 0x$filesize && run nand_write_confirm && run nand_write_cal_wrsize && mtd erase u-boot && mtd write u-boot $loadaddr 0x0 0x$wrsize && setenv wrsize && run nand_verify_uboot
ubi_read_firmware=ubi part ubi && ubi read $loadaddr fit
ubi_write_cal_ersize=setexpr ersize 0x$filesize + 0x1efff && setexpr ersize 0x$ersize / 0x1f000 && setexpr ersize 0x$ersize * 0x1f000
ubi_write_firmware=ubi detach ; mtd erase ubi && ubi part ubi && run ubi_write_cal_ersize && ubi create fit 0x$ersize dynamic && ubi write $loadaddr fit $filesize && ubi create rootfs_data - dynamic
