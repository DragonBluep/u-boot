
if SOC_MT7620

config DEBUG_UART_BOARD_INIT
	default y

choice
	prompt "Board select"

config BOARD_MT7620_RFB
	bool "MediaTek MT7620 RFB"
	help
	  The reference design of MT7620A (WS2120). The board has 64 MiB DDR2,
	  8 MiB SPI-NOR flash, 1 built-in 6 port switch (two GE PHYs and five
	  FE PHYs,one port can be configured to use either FE PHY or GE PHY),
	  1 UART, 1 USB host, 1 SDXC, 1 PCIe socket and JTAG pins.

config BOARD_MT7620_MT7530_RFB
	bool "MediaTek MT7620-MT7530 RFB"
	help
	  The reference design of MT7620DA (MTKC712). The board has 64 MiB
	  intergrated DDR2 KGD, 16 MiB SPI-NOR flash, an external 5-port giga
	  switch MT7530 and 1 UART.

config BOARD_DOMYWIFI_DM203
	bool "DomyWifi DM203 Wireless Router"

config BOARD_FOCUSMEDIA_MT7620A
	bool "FocusMedia MT7620A Wireless Router"

config BOARD_GBCOM_N3000
	bool "GBCOM N3000-06 Wireless Router"

config BOARD_HAIER_HWL1W
	bool "Haier HW-L1W Wireless Router"

config BOARD_HIWIFI_HC5661
	bool "HiWiFi HC5661 Wireless Router"

config BOARD_HIWIFI_HC5861
	bool "HiWiFi HC5861 Wireless Router"

config BOARD_LBLINK_BLW1210
	bool "LB-Link BL-W1210 Wireless Router"

config BOARD_PHICOMM_K2
	bool "Phicomm K2 Wireless Router"

config BOARD_PHICOMM_K2G
	bool "Phicomm K2G Wireless Router"

config BOARD_YOUKU_X2
	bool "Youku X2 Wireless Router"

config BOARD_YOUKU_YKL1C
	bool "Youku YK-L1c Wireless Router"

endchoice

choice
	prompt "CPU frequency select"
	default CPU_FREQ_580MHZ

