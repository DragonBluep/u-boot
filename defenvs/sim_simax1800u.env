baudrate=115200
loadaddr=86000000
ipaddr=192.168.1.1
serverip=192.168.1.254
ethaddr=aa:bb:cc:dd:ee:ff
file_bootloader=u-boot.bin
file_firmware=firmware.bin
file_initramfs=initramfs.bin
bootcmd=if test x$ubien = xtrue ; then run ubi_read_firmware ; else run nand_read_firmware ; fi && bootm $loadaddr
bootmenu_0=[36m[1mRun default boot command[0m=run bootcmd ; echo [35m[1mFailed to load system![0m ; sleep 3 && reset
bootmenu_1=[36m[1mBoot System from Flash[0m=run bootcmd ; run confirm_return
bootmenu_2=[32m[1mBoot System from TFTP[0m=run tftp_load_initramfs ; run confirm_return
bootmenu_3=[32m[1mLoad System via TFTP then write to Flash[0m=run tftp_restore_system ; run confirm_return
bootmenu_4=[33m[1mLoad U-Boot via TFTP then write to Flash[0m=run tftp_update_uboot ; run confirm_return
bootmenu_5=[33m[1mLoad U-Boot via TTL then write to Flash[0m=run uart_update_uboot ; run confirm_return
bootmenu_6=[31m[1mSwitch NAND UBI layer[0m=run switch_nandubi ; run confirm_return
bootmenu_7=[31m[1mReboot[0m=reset
check_itbimg=imsz $loadaddr fitsize && setexpr fitsize $fitsize + 80000 && extsize=$fitsize && setenv fitsize && test $extsize -gt $filesize
confirm_continue=askenv char [35m[1mContinue? [Y/n][0m 1 && token=$char && setenv char ; test x$token = xy || test x$token = xY
confirm_return=askenv - [35m[1mPress ENTER to return to the boot menu![0m ; bootmenu 60
md5_verify_uboot=md5sum $loadaddr $filesize md5 && hash=$md5 && setenv md5 && mtd read u-boot $loadaddr && md5sum -v $loadaddr $filesize $hash
nand_prep_erase=setexpr iosize $filesize + 1ffff && setexpr iosize $iosize / 20000 && setexpr iosize $iosize * 20000
nand_prep_read=setexpr imgsize $imgsize + 7ff && setexpr imgsize $imgsize / 800 && setexpr imgsize $imgsize * 800
nand_prep_write=setexpr iosize $filesize + 7ff && setexpr iosize $iosize / 800 && setexpr iosize $iosize * 800
nand_read_firmware=mtd read firmware $loadaddr 0 20000 && imsz $loadaddr imgsize && run nand_prep_read && mtd read firmware $loadaddr 0 $imgsize && setenv imgsize
nand_verify_uboot=if run md5_verify_uboot ; then echo [35m[1mU-Boot upgrade successful![0m ; else echo [35m[1mU-Boot upgrade failed![0m ; fi
nand_write_firmware=ubi detach && run nand_prep_erase && mtd erase firmware 0 $iosize && run nand_prep_write && mtd write firmware $loadaddr 0 $iosize && setenv iosize
nand_write_uboot=run confirm_continue && mtd erase u-boot && run nand_prep_write && mtd write u-boot $loadaddr 0 $iosize && setenv iosize
setup_netconsole=setenv ncip $serverip && setenv stdin nc && setenv stdout nc && setenv stderr nc
setup_ttlconsole=setenv stderr serial@1e000c00 && setenv stdout serial@1e000c00 && setenv stdin serial@1e000c00 && setenv ncip
switch_console=if test x$stdin = xnc ; then run setup_ttlconsole && setenv bootdelay ; else run setup_netconsole && setenv bootdelay 60 ; fi
switch_nandubi=if test x$ubien = xtrue ; then setenv ubien false && echo [35m[1mUBI detached![0m ; else setenv ubien true && echo [35m[1mUBI attached![0m ; fi && saveenv
tftp_load_initramfs=tftpboot $loadaddr $file_initramfs && bootm $loadaddr
tftp_load_initramfs_loop=setenv cnt 0 ; while test $cnt -lt 20 ; do run tftp_load_initramfs ; setexpr cnt $cnt + 1 ; sleep 3 ; done ; setenv cnt
tftp_restore_system=tftpboot $loadaddr $file_firmware && if test x$ubien = xtrue && run check_itbimg ; then run ubi_write_firmware ; else run nand_write_firmware ; fi && run bootcmd
tftp_restore_system_loop=setenv cnt 0 ; while test $cnt -lt 20 ; do run tftp_restore_system ; setexpr cnt $cnt + 1 ; sleep 3 ; done ; setenv cnt
tftp_update_uboot=mw.b $loadaddr ff 80000 && tftpboot $loadaddr $file_bootloader && run nand_write_uboot && run nand_verify_uboot
uart_update_uboot=mw.b $loadaddr ff 80000 && loadx $loadaddr $baudrate && run nand_write_uboot && run nand_verify_uboot
ubi_erase_userdata=ubi part firmware && ubi check rootfs_data && ubi remove rootfs_data && ubi create rootfs_data - dynamic && reset
ubi_prep_write=setexpr iosize $filesize + 1efff && setexpr iosize $iosize / 1f000 && setexpr iosize $iosize * 1f000
ubi_read_firmware=ubi part firmware && if ubi check kernel ; then ubi read $loadaddr kernel ; else ubi read $loadaddr fit ; fi
ubi_write_firmware=ubi detach && mtd erase firmware && ubi part firmware && run ubi_prep_write && ubi create fit $iosize dynamic && setenv iosize && ubi write $loadaddr fit $filesize
ubien=true
